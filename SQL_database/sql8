create or replace function public.ensure_today_stats_for_user(
  p_user_id uuid
)
returns void
language plpgsql
security definer
set search_path = public
as $$
declare
  today date := (now() at time zone 'utc')::date;
  yesterday date := today - 1;
  r record;
begin
  -- Ensure daily_user_stats
  insert into daily_user_stats (
    user_id, date,
    global_streak, max_global_streak,
    cards_reviewed, cards_learned,
    streak_state, updated_at
  )
  select
    p_user_id,
    today,
    coalesce(y.global_streak, 0),
    coalesce(y.max_global_streak, 0),
    0, 0,
    'inactive',
    now()
  from daily_user_stats y
  where y.user_id = p_user_id
    and y.date = yesterday
  on conflict (user_id, date) do nothing;

  -- Ensure daily_deck_stats rows (carry streaks ONLY)
  insert into daily_deck_stats (
    user_id, deck_id, date,
    deck_streak, max_streak,
    streak_state, updated_at
  )
  select
    d.user_id,
    d.id,
    today,
    coalesce(y.deck_streak, 0),
    greatest(coalesce(y.max_streak, 0), coalesce(d.max_streak, 0)),
    'inactive',
    now()
  from decks d
  left join daily_deck_stats y
    on y.deck_id = d.id
   and y.date = yesterday
  where d.user_id = p_user_id
  on conflict (user_id, deck_id, date) do nothing;

  -- 🔴 CRITICAL FIX: recompute counts for ALL decks
  for r in
    select id from decks where user_id = p_user_id
  loop
    perform public.refresh_deck_counts(r.id);
  end loop;
end;
$$;

grant execute on function public.ensure_today_stats_for_user(uuid) to authenticated;
