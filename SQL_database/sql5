-- TRIGGER FUNCTIONS
-- ============================================================

-- Card progress → deck refresh
create or replace function public._trg_card_progress_refresh()
returns trigger
language plpgsql
as $$
declare
  v_deck_id uuid;
begin
  if tg_table_name = 'card_a_progress' then
    select deck_id into v_deck_id
    from public.cards_a
    where id = coalesce(new.card_id, old.card_id);
  else
    select deck_id into v_deck_id
    from public.cards_c
    where id = coalesce(new.card_id, old.card_id);
  end if;

  if v_deck_id is not null then
    perform public.refresh_deck_counts(v_deck_id);
  end if;

  return coalesce(new, old);
end;
$$;

-- Card definition → deck refresh
create or replace function public._trg_cards_refresh()
returns trigger
language plpgsql
as $$
begin
  perform public.refresh_deck_counts(coalesce(new.deck_id, old.deck_id));
  return coalesce(new, old);
end;
$$;

-- Apply triggers
drop trigger if exists trg_refresh_a on public.card_a_progress;
create trigger trg_refresh_a
after insert or update or delete
on public.card_a_progress
for each row
execute function public._trg_card_progress_refresh();

drop trigger if exists trg_refresh_c on public.card_c_progress;
create trigger trg_refresh_c
after insert or update or delete
on public.card_c_progress
for each row
execute function public._trg_card_progress_refresh();

drop trigger if exists trg_card_def_a on public.cards_a;
create trigger trg_card_def_a
after insert or update or delete
on public.cards_a
for each row
execute function public._trg_cards_refresh();

drop trigger if exists trg_card_def_c on public.cards_c;
create trigger trg_card_def_c
after insert or update or delete
on public.cards_c
for each row
execute function public._trg_cards_refresh();
