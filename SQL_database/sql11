create or replace function public._trg_card_progress_refresh()
returns trigger
language plpgsql
as $$
declare v_deck_id uuid;
begin
  if tg_table_name = 'card_a_progress' then
    select deck_id into v_deck_id from cards_a where id = coalesce(new.card_id, old.card_id);
  else
    select deck_id into v_deck_id from cards_c where id = coalesce(new.card_id, old.card_id);
  end if;

  if v_deck_id is not null then
    perform public.refresh_deck_counts(v_deck_id);
  end if;

  return coalesce(new, old);
end;
$$;

create or replace function public._trg_cards_refresh()
returns trigger
language plpgsql
as $$
begin
  perform public.refresh_deck_counts(coalesce(new.deck_id, old.deck_id));
  return coalesce(new, old);
end;
$$;

drop trigger if exists trg_refresh_a on card_a_progress;
create trigger trg_refresh_a after insert or update or delete on card_a_progress
for each row execute function public._trg_card_progress_refresh();

drop trigger if exists trg_refresh_c on card_c_progress;
create trigger trg_refresh_c after insert or update or delete on card_c_progress
for each row execute function public._trg_card_progress_refresh();

drop trigger if exists trg_cards_a on cards_a;
create trigger trg_cards_a after insert or update or delete on cards_a
for each row execute function public._trg_cards_refresh();

drop trigger if exists trg_cards_c on cards_c;
create trigger trg_cards_c after insert or update or delete on cards_c
for each row execute function public._trg_cards_refresh();
