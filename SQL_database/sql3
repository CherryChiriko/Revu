-- Card A progress trigger
create or replace function public._trg_card_a_progress_refresh()
returns trigger
language plpgsql
as $$
declare
  v_deck_id uuid;
begin
  if tg_op = 'INSERT' or tg_op = 'UPDATE' then
    select deck_id into v_deck_id
    from public.cards_a
    where id = coalesce(new.card_id, old.card_id);

    if found then
      perform public.refresh_deck_counts(v_deck_id);
    end if;
    return coalesce(new, old);

  elsif tg_op = 'DELETE' then
    select deck_id into v_deck_id
    from public.cards_a
    where id = old.card_id;

    if found then
      perform public.refresh_deck_counts(v_deck_id);
    end if;
    return old;
  end if;

  return null;
end;
$$;

drop trigger if exists card_a_progress_refresh_trigger on public.card_a_progress;

create trigger card_a_progress_refresh_trigger
after insert or update or delete on public.card_a_progress
for each row execute procedure public._trg_card_a_progress_refresh();

