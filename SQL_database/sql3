-- Cards table trigger (A and C)
create or replace function public._trg_cards_refresh()
returns trigger
language plpgsql
as $$
begin
  if tg_op = 'INSERT' or tg_op = 'UPDATE' then
    perform public.refresh_deck_counts(new.deck_id);
    return new;
  elsif tg_op = 'DELETE' then
    perform public.refresh_deck_counts(old.deck_id);
    return old;
  end if;

  return null;
end;
$$;

drop trigger if exists cards_a_refresh_trigger on public.cards_a;
drop trigger if exists cards_c_refresh_trigger on public.cards_c;

create trigger cards_a_refresh_trigger
after insert or update or delete on public.cards_a
for each row execute procedure public._trg_cards_refresh();

create trigger cards_c_refresh_trigger
after insert or update or delete on public.cards_c
for each row execute procedure public._trg_cards_refresh();