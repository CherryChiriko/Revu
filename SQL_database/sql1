

-- ============================================================
-- FUNCTION: refresh_daily_stats_for_user
-- Purpose: Recompute today's deck availability for a user
-- Called by: Frontend on app startup
-- ============================================================

create or replace function public.refresh_daily_stats_for_user(
  p_user_id uuid
)
returns void
language plpgsql
security definer
set search_path = public
as $$
declare
  r record;
begin
  for r in
    select id as deck_id
    from decks
    where user_id = p_user_id
  loop
    perform public.refresh_deck_counts(r.deck_id);
  end loop;
end;
$$;

grant execute on function public.refresh_daily_stats_for_user(uuid) to authenticated;

-- ============================================================
-- FUNCTION: refresh_deck_counts
-- ============================================================
create or replace function public.refresh_deck_counts(p_deck_id uuid)
returns void
language plpgsql
security definer
set search_path = public
as $$
declare
  v_user_id uuid;
  today date := (now() at time zone 'utc')::date;
begin
  -- Get user_id for this deck
  select user_id into v_user_id from public.decks where id = p_deck_id;
  if not found then return; end if;

  -- 1. Update Global Deck Totals (decks table)
  update public.decks d
  set
    cards_count = (
      select count(*) from (
        select id from public.cards_a where deck_id = p_deck_id
        union all
        select id from public.cards_c where deck_id = p_deck_id
      ) a
    )
  where d.id = p_deck_id;

  -- 2. Ensure Daily Row exists for today
  insert into public.daily_deck_stats (user_id, deck_id, date, updated_at)
  values (v_user_id, p_deck_id, today, now())
  on conflict (user_id, deck_id, date) do nothing;

  -- 3. Compute and Update counts
  update public.daily_deck_stats dds
  set
    new_count = counts.new_c,
    due_count = counts.due_c,
    waiting_count = counts.waiting_c,
    updated_at = now()
  from (
    with unified_progress as (
      -- Join progress with cards to filter by deck_id
      select cp.status, cp.due_date, cp.suspended
      from public.card_a_progress cp 
      join public.cards_a c on c.id = cp.card_id 
      where c.deck_id = p_deck_id
      union all
      select cp.status, cp.due_date, cp.suspended
      from public.card_c_progress cp 
      join public.cards_c c on c.id = cp.card_id 
      where c.deck_id = p_deck_id
    )
    select
      count(*) filter (where status = 'new' and not suspended) as new_c,
      count(*) filter (where status = 'waiting' and due_date <= (now() at time zone 'utc') and not suspended) as due_c,
      count(*) filter (where status = 'waiting' and (due_date > (now() at time zone 'utc') or due_date is null) and not suspended) as waiting_c
    from unified_progress
  ) counts
  where dds.deck_id = p_deck_id and dds.date = today;
end;
$$;


create or replace function public.ensure_today_stats_for_user(
  p_user_id uuid
)
returns void
language plpgsql
security definer
as $$
declare
  today date := (now() at time zone 'utc')::date;
  yesterday date := today - 1;
begin
  -- 1. Ensure daily_user_stats
  insert into daily_user_stats (
    user_id,
    date,
    global_streak,
    max_global_streak,
    streak_state,
    cards_reviewed,
    cards_learned,
    updated_at
  )
  select
    p_user_id,
    today,
    coalesce(y.global_streak, 0),
    coalesce(y.max_global_streak, 0),
    'inactive',
    0,
    0,
    now()
  from daily_user_stats y
  where y.user_id = p_user_id
    and y.date = yesterday
  on conflict (user_id, date) do nothing;

  -- 2. Ensure daily_deck_stats
  insert into daily_deck_stats (
    user_id,
    deck_id,
    date,
    deck_streak,
    max_streak,
    streak_state,
    updated_at
  )
  select
    d.user_id,
    d.id,
    today,
    coalesce(y.deck_streak, 0),
    greatest(
  coalesce(y.max_streak, 0),
  coalesce(d.max_streak, 0)
),
    'inactive',
    now()
  from decks d
  left join daily_deck_stats y
    on y.deck_id = d.id
   and y.date = yesterday
  where d.user_id = p_user_id
  on conflict (user_id, deck_id, date) do nothing;

  -- Recompute counts for all decks
perform public.refresh_deck_counts(d.id)
from decks d
where d.user_id = p_user_id;

end;
$$;

grant execute on function public.ensure_today_stats_for_user(uuid) to authenticated;

-- ============================================================
-- FUNCTION: update_streaks_after_session
-- ============================================================

create or replace function public.update_streaks_after_session(
  p_user_id uuid,
  p_deck_ids uuid[],
  p_cards_reviewed integer,
  p_cards_learned integer,
  p_review_limit integer,
  p_learn_limit integer
)
returns void
language plpgsql
security definer
as $$
declare
  today date := (now() at time zone 'utc')::date;
  yesterday date := today - 1;
  global_completed boolean :=
    p_cards_reviewed >= p_review_limit
    or p_cards_learned >= p_learn_limit;
  d_id uuid;
begin
  -- Ensure daily rows exist for studied decks
  foreach d_id in array p_deck_ids loop
    insert into daily_deck_stats (
      user_id, deck_id, date,
      deck_streak, max_streak, streak_state, updated_at
    )
    values (
      p_user_id, d_id, today,
      0, 0, 'inactive', now()
    )
    on conflict (user_id, deck_id, date) do nothing;
  end loop;

  -- Ensure daily user stats row exists
  insert into daily_user_stats (
    user_id, date,
    cards_reviewed, cards_learned,
    global_streak, max_global_streak, streak_state, updated_at
  )
  values (
    p_user_id, today,
    0, 0,
    0, 0, 'inactive', now()
  )
  on conflict (user_id, date) do nothing;

  -- Accumulate daily counters
  update daily_user_stats
  set
    cards_reviewed = cards_reviewed + p_cards_reviewed,
    cards_learned  = cards_learned  + p_cards_learned,
    updated_at     = now()
  where user_id = p_user_id
    and date = today;

  -- Activate deck streaks
  update daily_deck_stats d
  set
    deck_streak = coalesce(y.deck_streak, 0) + 1,
    max_streak  = greatest(d.max_streak, coalesce(y.deck_streak, 0) + 1),
    streak_state = 'active',
    updated_at  = now()
  from (
    select user_id, deck_id, deck_streak, max_streak
    from daily_deck_stats
    where user_id = p_user_id
      and date = yesterday
  ) y
  where d.user_id = p_user_id
    and d.deck_id = any(p_deck_ids)
    and d.date = today
    and d.streak_state = 'inactive'
    and y.deck_id = d.deck_id
    and y.user_id = d.user_id;

  -- First-time decks
  update daily_deck_stats d
  set
    deck_streak = 1,
    max_streak  = greatest(d.max_streak, 1),
    streak_state = 'active',
    updated_at  = now()
  where d.user_id = p_user_id
    and d.deck_id = any(p_deck_ids)
    and d.date = today
    and d.streak_state = 'inactive'
    and not exists (
      select 1 from daily_deck_stats y
      where y.user_id = p_user_id
        and y.deck_id = d.deck_id
        and y.date = yesterday
    );

  -- Activate global streak
  if global_completed then
    -- Continue from yesterday
    update daily_user_stats u
    set
      global_streak = coalesce(y.global_streak, 0) + 1,
      max_global_streak = greatest(u.max_global_streak, coalesce(y.global_streak, 0) + 1),
      streak_state = 'active',
      updated_at = now()
    from (
      select user_id, global_streak, max_global_streak
      from daily_user_stats
      where user_id = p_user_id
        and date = yesterday
    ) y
    where u.user_id = p_user_id
      and u.date = today
      and u.streak_state = 'inactive'
      and y.user_id = u.user_id;

    -- First-time user
    update daily_user_stats u
    set
      global_streak = 1,
      max_global_streak = greatest(u.max_global_streak, 1),
      streak_state = 'active',
      updated_at = now()
    where u.user_id = p_user_id
      and u.date = today
      and u.streak_state = 'inactive'
      and not exists (
        select 1 from daily_user_stats y
        where y.user_id = p_user_id
          and y.date = yesterday
      );
  end if;
end;
$$;

-- ============================================================
-- FUNCTION: resolve_inactive_streaks
-- ============================================================
create or replace function public.resolve_inactive_streaks()
returns void
language plpgsql
security definer
as $$
declare
  today date := (now() at time zone 'utc')::date;
  yesterday date := today - 1;
begin
  -- 1. Deck streaks missed yesterday
  update daily_deck_stats
  set
    deck_streak = 0,
    streak_state = 'inactive',
    updated_at = now()
  where date = yesterday
    and streak_state = 'inactive'
    and (due_count > 0 or new_count > 0);

  -- 2. Decks frozen yesterday (nothing available)
  update daily_deck_stats
  set
    streak_state = 'frozen',
    updated_at = now()
  where date = yesterday
    and streak_state = 'inactive'
    and due_count = 0
    and new_count = 0;

  -- 3. Global streak missed
  update daily_user_stats u
  set
    global_streak = 0,
    streak_state = 'inactive',
    updated_at = now()
  where u.date = yesterday
    and u.streak_state = 'inactive'
    and exists (
      select 1
      from daily_deck_stats d
      where d.user_id = u.user_id
        and d.date = yesterday
        and (d.due_count > 0 or d.new_count > 0)
    );

  -- 4. Global frozen
  update daily_user_stats u
  set
    streak_state = 'frozen',
    updated_at = now()
  where u.date = yesterday
    and u.streak_state = 'inactive'
    and not exists (
      select 1
      from daily_deck_stats d
      where d.user_id = u.user_id
        and d.date = yesterday
        and (d.due_count > 0 or d.new_count > 0)
    );
end;
$$;
